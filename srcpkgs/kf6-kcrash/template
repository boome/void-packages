# Template file for 'kf6-kcrash'
pkgname=kf6-kcrash
version=6.27.0
revision=1
build_style=cmake
hostmakedepends="extra-cmake-modules qt6-tools qt6-base "
makedepends="kf6-kcoreaddons-devel"
short_desc="KDE Graceful handling of application crashes"
maintainer="John <me@johnnynator.dev>"
license="LGPL-2.1-or-later"
homepage="https://invent.kde.org/frameworks/kcrash"
distfiles="${KDE_SITE}/frameworks/${version%.*}/${pkgname#kf6-}-${version}.tar.xz"
checksum=f8e1083863dac2c07068b10614ca7d4b52c6920df0228854cfc37e0d6578d902

kf6-kcrash-devel_package() {
	depends="$makedepends ${sourcepkg}>=${version}_${revision}"
	short_desc+=" - development files"
	pkg_install() {
		vmove usr/include
		vmove usr/lib/cmake
		vmove "usr/lib/*.so"
	}
}
