# Template file for 'kf6-kcalendarcore'
pkgname=kf6-kcalendarcore
version=6.27.0
revision=1
build_style=cmake
configure_args="-DKDE_INSTALL_QMLDIR=lib/qt6/qml"
hostmakedepends="extra-cmake-modules qt6-tools qt6-base qt6-declarative-host-tools shiboken6 python3-build clang llvm python3-setuptools"
makedepends="qt6-base-devel libical-devel qt6-declarative-devel python3-devel libshiboken6-devel libpyside6-devel"
checkdepends="perl"
short_desc="Library for Interfacing with Calendars"
maintainer="John <me@johnnynator.dev>"
license="LGPL-2.1-or-later"
homepage="https://invent.kde.org/frameworks/kcalendarcore"
distfiles="${KDE_SITE}/frameworks/${version%.*}/${pkgname#kf6-}-${version}.tar.xz"
checksum=4228869722c5bb5325b7c5b10555e6b747bde0e36cbd43519d8681fe3b383173

do_check() {
	cd build
	# disable failing tests
	ctest -E "testicaltimezones|Compat-AppleICal_1.5.ics|Compat-KOrganizer_3.1a.ics|Compat-Mozilla_1.0.ics"
}

kf6-kcalendarcore-devel_package() {
	depends="$makedepends ${sourcepkg}>=${version}_${revision}"
	short_desc+=" - development files"
	pkg_install() {
		vmove usr/include
		vmove usr/lib/pkgconfig
		vmove usr/lib/cmake
		vmove "usr/lib/*.so"
	}
}
